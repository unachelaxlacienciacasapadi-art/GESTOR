# PostgreSQL Database Connection
# Example: postgresql://user:password@host:5432/database
DATABASE_URL="postgresql://usuario:password@host:puerto/db"

# JWT Secret for authentication tokens (min 32 characters, generate a secure random string)
JWT_SECRET="secreto-aleatorio-seguro-minimo-32-chars"

# Admin Panel Credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="tu-password-aqui"

# Resend Email API Key (for confirmation emails)
# Get your key from https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxx"
